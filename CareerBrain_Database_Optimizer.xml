        log.info(f"Sampled {len(samples)} stratified entries across 5 problem categories")

        stats: dict = {"total": len(samples), "fixed": 0, "lived_experience": 0,
                       "llm_rewrites": 0, "fix_counts": {}}

        for item in samples:
