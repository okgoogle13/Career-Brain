{
  "schema_version": "2.3",
  "template_id": "theme_broadside_press",
  "tier": 1,
  "tier_label": "ATS Standard",
  "doc_type": "resume",
  "target_sector": [
    "government",
    "policy",
    "legal"
  ],
  "region": "AU",
  "placeholder_schema": "PLACEHOLDERSCHEMAV2",
  "description": "Editorial broadsheet theme with pure-black Georgia serif typography, crimson editor's-ink metadata, and sharp offset structural rules.",
  "visual_identity": {
    "theme_name": "Broadside Press",
    "mood": "journalistic, urgent, factual, uncompromising",
    "motif_name": "heavy headline tracking and sharp offsets",
    "density_target": "high",
    "silhouette": "dense, text-heavy, column-mimicking",
    "personality_axis": "truth-seeking, articulate, bold",
    "header_silhouette": "massive serif typography dominating the top margin, tightly stacked",
    "section_emphasis_pattern": "divider-led",
    "contrast_intensity": "high"
  },
  "ats_constraints": {
    "columns": 1,
    "allows_tables": false,
    "allows_images": false,
    "allows_text_boxes": false,
    "allows_headers_footers": false,
    "font_family": [
      "Source Serif 4",
      "Georgia"
    ],
    "content_layer": "all essential content must remain plain text in normal reading order and selectable",
    "forbidden_glyphs": [
      "icons",
      "emoji",
      "ornamental bullets",
      "nonstandard ligatures",
      "special symbols used as decoration",
      "layout-only unicode art"
    ]
  },
  "palette": {
    "base_colours": [
      "#0B0B0B",
      "#2A2A2A",
      "#5A5A5A"
    ],
    "complementary_accent": "#8B0000",
    "neutral_surface": "#FFFFFF",
    "neutral_text": "#0B0B0B",
    "neutral_background": "#FFFFFF",
    "supporting_neutral": "#F5F5F5"
  },
  "typography": {
    "base_font": "Source Serif 4",
    "base_size_pt": 10.5,
    "line_spacing": 1.3,
    "spacing_after_pt": 6,
    "section_heading_tracking_pt": 0.0,
    "section_heading_size_pt": 13,
    "section_heading_weight": 700
  },
  "page": {
    "margins_in": {
      "top": 0.6,
      "right": 0.7,
      "bottom": 0.6,
      "left": 0.7
    },
    "paper_size": "A4",
    "orientation": "portrait",
    "single_column": true,
    "reading_order": "top_to_bottom_left_to_right",
    "export_safe": "Google Docs and PDF export compatible"
  },
  "bands": {
    "strategy": "sharp, newspaper-like structural divisions using offset rules",
    "placement": [
      "section separator zones"
    ],
    "intensity": "moderate",
    "height_rule": {
      "min_pt": 1,
      "max_pt": 2,
      "default_pt": 1
    },
    "band_targets": [
      "section separator zones"
    ],
    "highlight_band_targets": [
      "metadata strip"
    ],
    "band_placement_profile": "divider_led",
    "accent_placement_profile": "metadata_only"
  },
  "dividers": {
    "grammar": "sharp solid rules with offset breaks between sections",
    "frequency": "frequent",
    "weight": "thin-to-medium",
    "divider_targets": [
      "between sections",
      "between role and achievement clusters"
    ],
    "divider_rhythm": "progressive"
  },
  "accent_logic": {
    "primary_use": [
      "dates",
      "locations",
      "sharp structural offset rules"
    ],
    "complementary_accent_role": "crimson behaves like an editor's red pen, marking metadata and structural breaks but never narrative text",
    "allowed_scope": [
      "metadata blocks",
      "specific horizontal rules"
    ],
    "forbidden_scope": [
      "body text",
      "major section headings",
      "background fills"
    ],
    "accent_balance": "crimson acts as the \"red ink\" editor's pen, used strictly for dates, locations, and structural separations, never for narrative text",
    "contrast_intensity": "high"
  },
  "theme_specific_rules": {
    "must_include": [
      "pure black Georgia font",
      "massive tightly-stacked header",
      "crimson metadata",
      "sharp offset dividers"
    ],
    "forbidden_repeats": [
      "same top-of-page structure across themes",
      "same section label treatment across themes",
      "same divider grammar as previous theme",
      "same chip treatment as previous theme",
      "same band placement as previous theme",
      "tonal-only palette dependency"
    ],
    "visual_differentiators": [
      "editorial/newspaper broadsheet aesthetic",
      "ultra-high contrast serif",
      "deep crimson editor's-ink accents"
    ],
    "anti_generic_rules": [
      "do not use sans-serif",
      "do not use wide tracking on headings",
      "do not soften black to dark grey"
    ],
    "non_reuse_constraints": [
      "no repeated top-of-page pattern",
      "no repeated divider grammar from previous theme",
      "no repeated band placement from previous theme"
    ],
    "adjacent_theme_difference_rules": [
      "must differ from previous theme in band placement",
      "must differ from previous theme in divider rhythm",
      "must differ from previous theme in accent placement"
    ]
  },
  "section_heading_style": {
    "font_color": "#0B0B0B",
    "text_transform": "uppercase",
    "decoration": "sharp solid rules with offset breaks between sections",
    "accent_color": "#A01818"
  },
  "body_text_color": "#0B0B0B",
  "muted_text_color": "#3A3A3A",
  "skills_background_tint": "#F5F5F5",
  "avoid_list": [
    "tonal-only palette",
    "same top-of-page structure",
    "same divider grammar as previous theme",
    "same chip treatment as previous theme",
    "generic safe fallback",
    "over-softened hierarchy",
    "repeated band placement",
    "multi-column layout",
    "sidebar layout",
    "text boxes",
    "layout tables",
    "floating objects",
    "decorative graphics",
    "icons",
    "images",
    "headers and footers for essential content",
    "low-contrast body text",
    "sans-serif fonts",
    "wide tracking",
    "dark grey instead of pure black",
    "pastel accents"
  ],
  "legacy_fields": {
    "pre_premium_patch": {
      "ats_constraints.font_family": [
        "Georgia",
        "Calibri",
        "Arial"
      ],
      "typography.base_font": "Georgia",
      "typography.line_spacing": 1.24,
      "typography.spacing_after_pt": 6,
      "palette.base_colours": [
        "#000000",
        "#222222",
        "#444444"
      ],
      "palette.neutral_text": "#000000",
      "palette.neutral_background": "#FFFFFF",
      "body_text_color": "#000000",
      "muted_text_color": "#444444",
      "section_heading_style.font_color": "#000000",
      "section_heading_style.accent_color": "#8B0000",
      "skills_background_tint": "#F5F5F5"
    }
  },
  "complementary_accent": "#A01818",
  "heading_font_family": [
    "Archivo Black",
    "Arial"
  ]
}
