{
  "schema_version": "2.0",
  "template_id": "cover_letter_government_v1",
  "tier": 1,
  "tier_label": "ATS Clean",
  "doc_type": "cover_letter",
  "target_sector": ["government", "public_service", "local_council", "regulatory"],
  "region": "AU",
  "placeholder_schema": "PLACEHOLDER_SCHEMA_V2",
  "description": "Government cover letter. Calibri throughout with Forest Green and Sage accents. Conservative single-column layout for AU public service and statutory roles. Six blocks: name_header, contact_info, employer_info, salutation, body_paragraphs, closing.",

  "ats_constraints": {
    "columns": 1,
    "allows_tables": false,
    "allows_images": false,
    "allows_text_boxes": false,
    "allows_headers_footers": false,
    "font_family": "Calibri",
    "content_layer": "body_only",
    "forbidden_glyphs": ["•", "✔", "★", "❖", "●", "✅", "❌", "|"]
  },

  "palette": {
    "forest_green": "#2F855A",
    "dark_grey": "#2D3748",
    "sage_green": "#68D391",
    "sage_light": "#F0FFF4",
    "body_text": "#1A1A1A",
    "muted_text": "#4A5568",
    "rule_sage": "#C6F6D5",
    "white": "#FFFFFF"
  },

  "typography": {
    "base_font": "Calibri",
    "base_size_pt": 11,
    "line_spacing": 1.15,
    "spacing_after_pt": 6,
    "section_heading_tracking_pt": 0,
    "section_heading_size_pt": 13
  },

  "page": {
    "margin_top_cm": 1.9,
    "margin_bottom_cm": 1.9,
    "margin_left_cm": 1.9,
    "margin_right_cm": 1.9,
    "background_color": "#FFFFFF"
  },

  "blocks": [
    {
      "block_id": "name_header",
      "type": "name_block",
      "order": 1,
      "tokens": ["{{CONTACT_NAME}}"],
      "content": "{{CONTACT_NAME}}",
      "visualConfig": {
        "font_size_pt": 17,
        "font_weight": "bold",
        "font_color": "#2F855A",
        "text_align": "left",
        "padding_top_pt": 0,
        "padding_bottom_pt": 2,
        "letter_spacing": "normal",
        "border_bottom": {
          "color": "#2F855A",
          "width_pt": 0.5,
          "style": "solid"
        }
      }
    },

    {
      "block_id": "contact_info",
      "type": "contact_block",
      "order": 2,
      "tokens": [
        "{{CONTACT_PHONE}}",
        "{{CONTACT_EMAIL}}",
        "{{CONTACT_LOCATION}}"
      ],
      "content": "{{CONTACT_PHONE}}    {{CONTACT_EMAIL}}    {{CONTACT_LOCATION}}",
      "visualConfig": {
        "font_size_pt": 10,
        "font_color": "#4A5568",
        "text_align": "left",
        "padding_top_pt": 3,
        "padding_bottom_pt": 18,
        "line_spacing": 1.15,
        "separator": "inline_spaced"
      }
    },

    {
      "block_id": "employer_info",
      "type": "employer_block",
      "order": 3,
      "tokens": [
        "{{EMPLOYER_CONTACT_NAME}}",
        "{{EMPLOYER_ORG}}",
        "{{EMPLOYER_ADDRESS}}"
      ],
      "content": "{{EMPLOYER_CONTACT_NAME}}\n{{EMPLOYER_ORG}}\n{{EMPLOYER_ADDRESS}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.15,
        "margin_bottom_pt": 14,
        "separator": "line_break"
      }
    },

    {
      "block_id": "salutation",
      "type": "salutation_block",
      "order": 4,
      "tokens": [
        "{{CURRENT_DATE}}",
        "{{SALUTATION}}"
      ],
      "content": "{{CURRENT_DATE}}\n\n{{SALUTATION}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.15,
        "margin_bottom_pt": 10
      }
    },

    {
      "block_id": "body_paragraphs",
      "type": "body_block",
      "order": 5,
      "tokens": [
        "{{HOOK_PARAGRAPH}}",
        "{{BRIDGE_PARAGRAPH}}",
        "{{EVIDENCE_PARAGRAPH_1}}",
        "{{EVIDENCE_PARAGRAPH_2}}"
      ],
      "content": "{{HOOK_PARAGRAPH}}\n\n{{BRIDGE_PARAGRAPH}}\n\n{{EVIDENCE_PARAGRAPH_1}}\n\n{{EVIDENCE_PARAGRAPH_2}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.3,
        "paragraph_spacing_after_pt": 10
      }
    },

    {
      "block_id": "closing",
      "type": "closing_block",
      "order": 6,
      "tokens": [
        "{{CLOSING_PARAGRAPH}}"
      ],
      "content": "{{CLOSING_PARAGRAPH}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.3,
        "margin_top_pt": 8
      }
    }
  ]
}
