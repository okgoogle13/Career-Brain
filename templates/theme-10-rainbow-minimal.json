{
  "schema_version": "2.3",
  "template_id": "theme_rainbow_minimal",
  "tier": 1,
  "tier_label": "ATS Standard",
  "doc_type": "resume",
  "target_sector": [],
  "region": "AU",
  "placeholder_schema": "PLACEHOLDERSCHEMAV2",
  "description": "Playful but disciplined minimal theme with restrained rainbow micro-accents and a very clean single-column structure.",
  "visual_identity": {
    "theme_name": "Rainbow Minimal",
    "mood": "bright, optimistic, disciplined",
    "motif_name": "controlled spectrum",
    "density_target": "open",
    "silhouette": "minimal",
    "personality_axis": "confident, clear, approachable",
    "header_silhouette": "simple",
    "section_emphasis_pattern": "label-led with thin rules",
    "contrast_intensity": "medium"
  },
  "ats_constraints": {
    "columns": 1,
    "allows_tables": false,
    "allows_images": false,
    "allows_text_boxes": false,
    "allows_headers_footers": false,
    "font_family": [
      "Calibri",
      "Arial",
      "Georgia"
    ],
    "content_layer": "all essential content must remain plain text in normal reading order and selectable",
    "forbidden_glyphs": [
      "icons",
      "emoji",
      "ornamental bullets",
      "nonstandard ligatures",
      "special symbols used as decoration",
      "layout-only unicode art"
    ]
  },
  "palette": {
    "base_colours": [
      "#111827",
      "#4B5563",
      "#9CA3AF"
    ],
    "complementary_accent": "#F472B6",
    "neutral_surface": "#FFFFFF",
    "neutral_text": "#111827",
    "neutral_background": "#FFFFFF",
    "supporting_neutral": "#F3F4F6",
    "spectrum_accents": [
      "#F97316",
      "#FACC15",
      "#22C55E",
      "#0EA5E9",
      "#6366F1",
      "#EC4899"
    ]
  },
  "typography": {
    "base_font": "Calibri",
    "base_size_pt": 10.5,
    "line_spacing": 1.24,
    "spacing_after_pt": 5,
    "section_heading_tracking_pt": 1.1,
    "section_heading_size_pt": 11,
    "section_heading_weight": 700
  },
  "page": {
    "margins_in": {
      "top": 0.65,
      "right": 0.7,
      "bottom": 0.65,
      "left": 0.7
    },
    "paper_size": "A4",
    "orientation": "portrait",
    "single_column": true,
    "reading_order": "top_to_bottom_left_to_right",
    "export_safe": "Google Docs and PDF export compatible"
  },
  "bands": {
    "strategy": "minimal, mostly label and micro-marker based",
    "placement": [
      "metadata strip"
    ],
    "intensity": "very subtle",
    "height_rule": {
      "min_pt": 1,
      "max_pt": 3,
      "default_pt": 2
    },
    "band_targets": [
      "small metadata strip"
    ],
    "highlight_band_targets": [
      "metadata strip"
    ],
    "band_placement_profile": "minimal",
    "accent_placement_profile": "micro_markers_only"
  },
  "dividers": {
    "grammar": "simple thin rules with occasional micro-color anchors",
    "frequency": "low to moderate",
    "weight": "thin",
    "divider_targets": [
      "between sections",
      "between grouped metadata blocks"
    ],
    "divider_rhythm": "simple"
  },
  "accent_logic": {
    "primary_use": [
      "small section labels",
      "micro markers before headings",
      "light metadata chips"
    ],
    "complementary_accent_role": "adds small hints of color across a spectrum while keeping the layout minimal and ATS-safe",
    "allowed_scope": [
      "small labels",
      "micro markers",
      "metadata chips",
      "selected separators"
    ],
    "forbidden_scope": [
      "full paragraphs",
      "large blocks",
      "background fills behind essential text",
      "text-over-image effects",
      "decorative emphasis that weakens readability",
      "rainbow gradients behind text"
    ],
    "accent_balance": "spectrum accents remain tiny and controlled",
    "contrast_intensity": "medium"
  },
  "theme_specific_rules": {
    "must_include": [
      "single-column text-first structure",
      "dark body text",
      "explicit motif",
      "explicit density target",
      "explicit band strategy (even if minimal)",
      "explicit divider grammar",
      "explicit accent placement",
      "clear header hierarchy"
    ],
    "forbidden_repeats": [
      "same top-of-page structure across themes",
      "same section label treatment across themes",
      "same divider grammar as previous theme",
      "same chip treatment as previous theme",
      "same band placement as previous theme",
      "tonal-only palette dependency"
    ],
    "visual_differentiators": [
      "multi-hue spectrum used only in micro elements",
      "very clean neutral canvas",
      "minimal dividers and bands compared to other themes"
    ],
    "anti_generic_rules": [
      "do not turn the spectrum into large decorative bands",
      "do not use gradients behind essential text",
      "do not revert to a single accent color that mimics other themes"
    ],
    "non_reuse_constraints": [
      "no repeated top-of-page pattern",
      "no repeated divider grammar from previous theme",
      "no repeated band placement from previous theme"
    ],
    "adjacent_theme_difference_rules": [
      "must differ from previous theme in band placement",
      "must differ from previous theme in divider rhythm",
      "must differ from previous theme in accent placement"
    ]
  },
  "section_heading_style": {
    "font_color": "#111827",
    "text_transform": "uppercase",
    "decoration": "minimal rule or micro marker only",
    "accent_color": "#F472B6"
  },
  "body_text_color": "#111827",
  "muted_text_color": "#6B7280",
  "skills_background_tint": "#F3F4F6",
  "avoid_list": [
    "tonal-only palette",
    "same top-of-page structure",
    "same divider grammar as previous theme",
    "same chip treatment as previous theme",
    "generic safe fallback",
