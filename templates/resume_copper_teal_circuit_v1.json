          "format": "{{ROLE_N_ORG}}   {{ROLE_N_DATES}}"
        },
        "bullet": {
          "font_size_pt": 10.5,
          "font_color": "#1D1C1A",
          "glyph": "-",
          "indent_pt": 14,
          "line_spacing": 1.26,
          "margin_bottom_pt": 2
        }
      }
