        "container": {
          "background_color": "#E8D4C6",
          "padding_top_pt": 6,
          "padding_bottom_pt": 6,
          "padding_left_pt": 10,
          "padding_right_pt": 10
        },
        "item": {
          "font_size_pt": 10.5,
          "font_color": "#1D1C1A",
          "separator": "comma",
          "display": "inline"
        }
      }
    },

    {
      "block_id": "experience_section",
      "type": "experience_block",
      "order": 6,
      "heading": "WORK EXPERIENCE",
      "max_roles": 6,
      "max_bullets_per_role": 4,
      "roles": [
        {
          "role_index": 1,
          "tokens": {
