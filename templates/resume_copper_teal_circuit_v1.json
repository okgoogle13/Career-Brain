{
  "schema_version": "2.0",
  "template_id": "resume_copper_teal_circuit_v1",
  "tier": 2,
  "tier_label": "ATS Modern",
  "doc_type": "resume",
  "target_sector": ["technology", "engineering", "finance", "design", "management_consulting"],
  "region": "AU",
  "placeholder_schema": "PLACEHOLDER_SCHEMA_V2",
  "description": "Premium dual-tone resume with copper and teal accents on a warm off-white ground. Arial throughout. Compact 11pt headings over near-black body text; structured copper rules under every section heading. ATS-safe: single column, no images, no text boxes.",

  "ats_constraints": {
    "columns": 1,
    "allows_tables": false,
    "allows_images": false,
    "allows_text_boxes": false,
    "allows_headers_footers": false,
    "font_family": "Arial",
    "content_layer": "body_only",
    "forbidden_glyphs": ["•", "✔", "★", "❖", "●", "✅", "❌", "|"]
  },

  "palette": {
    "copper_accent": "#9A5A3A",
    "teal_accent": "#2D8A8A",
    "body_text": "#1D1C1A",
    "muted_text": "#7D6A5A",
    "light_copper": "#E8D4C6",
    "background": "#FAF8F5"
  },

  "typography": {
    "base_font": "Arial",
    "base_size_pt": 10.5,
    "line_spacing": 1.26,
    "spacing_after_pt": 6,
    "section_heading_tracking_pt": 1.4,
    "section_heading_size_pt": 11
  },

  "page": {
    "margin_top_cm": 1.65,
    "margin_bottom_cm": 1.65,
    "margin_left_cm": 1.78,
    "margin_right_cm": 1.78,
    "background_color": "#FAF8F5"
  },

  "blocks": [
    {
      "block_id": "name_header",
      "type": "name_block",
      "order": 1,
      "tokens": ["{{CONTACT_NAME}}"],
      "content": "{{CONTACT_NAME}}",
      "visualConfig": {
        "font_size_pt": 22,
        "font_weight": "bold",
        "font_color": "#9A5A3A",
        "text_align": "left",
        "padding_top_pt": 0,
        "padding_bottom_pt": 2,
        "letter_spacing": "normal",
        "border_bottom": {
          "color": "#2D8A8A",
          "width_pt": 0.75,
          "style": "solid"
        },
        "margin_bottom_pt": 4
      }
    },

    {
      "block_id": "contact_info",
      "type": "contact_block",
      "order": 2,
      "tokens": [
        "{{CONTACT_PHONE}}",
        "{{CONTACT_EMAIL}}",
        "{{CONTACT_LOCATION}}"
      ],
      "content": "{{CONTACT_PHONE}}    {{CONTACT_EMAIL}}    {{CONTACT_LOCATION}}",
      "visualConfig": {
        "font_size_pt": 10,
        "font_color": "#7D6A5A",
        "text_align": "left",
        "padding_top_pt": 3,
        "padding_bottom_pt": 10,
        "line_spacing": 1.15,
        "separator": "inline_spaced"
      }
    },

    {
      "block_id": "role_headline",
      "type": "headline_block",
      "order": 3,
      "tokens": ["{{TARGET_ROLE}}"],
      "content": "{{TARGET_ROLE}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_weight": "bold",
        "font_color": "#1D1C1A",
        "text_align": "left",
        "padding_top_pt": 2,
        "padding_bottom_pt": 12
      }
    },

    {
      "block_id": "summary_section",
      "type": "summary_block",
      "order": 4,
      "heading": "PROFESSIONAL SUMMARY",
      "tokens": ["{{PROFESSIONAL_SUMMARY}}"],
      "content": "{{PROFESSIONAL_SUMMARY}}",
      "visualConfig": {
        "heading": {
          "font_size_pt": 11,
          "font_weight": "bold",
          "font_color": "#1D1C1A",
          "text_transform": "uppercase",
          "letter_spacing_pt": 1.4,
          "border_bottom": {
            "color": "#9A5A3A",
            "width_pt": 1.0,
            "style": "solid"
          },
          "margin_bottom_pt": 6
        },
        "body": {
          "font_size_pt": 10.5,
          "font_color": "#1D1C1A",
          "line_spacing": 1.26
        }
      }
    },

    {
      "block_id": "skills_section",
      "type": "skills_block",
      "order": 5,
      "heading": "KEY SKILLS",
      "tokens": [
        "{{SKILL_1}}",
        "{{SKILL_2}}",
        "{{SKILL_3}}",
        "{{SKILL_4}}",
        "{{SKILL_5}}",
        "{{SKILL_6}}"
      ],
      "layout": "grouped_inline",
      "visualConfig": {
        "heading": {
          "font_size_pt": 11,
          "font_weight": "bold",
          "font_color": "#1D1C1A",
          "text_transform": "uppercase",
          "letter_spacing_pt": 1.4,
          "border_bottom": {
            "color": "#9A5A3A",
            "width_pt": 1.0,
            "style": "solid"
          },
          "margin_bottom_pt": 6
