      "visualConfig": {
        "heading": {
          "font_size_pt": 11,
          "font_weight": "bold",
          "font_color": "#1D1C1A",
          "text_transform": "uppercase",
          "letter_spacing_pt": 1.4,
          "border_bottom": {
            "color": "#9A5A3A",
