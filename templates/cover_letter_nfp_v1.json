{
  "schema_version": "2.0",
  "template_id": "cover_letter_nfp_v1",
  "tier": 2,
  "tier_label": "ATS Bold",
  "doc_type": "cover_letter",
  "target_sector": ["community_services", "social_work", "non_profit", "advocacy"],
  "region": "AU",
  "placeholder_schema": "PLACEHOLDER_SCHEMA_V2",
  "description": "Not-for-profit cover letter with warm, mission-aligned visual identity. Calibri throughout with Ink Gold and Waratah Red accents. Single-column, ATS-safe. Six blocks: name_header, contact_info, employer_info, salutation, body_paragraphs, closing.",

  "ats_constraints": {
    "columns": 1,
    "allows_tables": false,
    "allows_images": false,
    "allows_text_boxes": false,
    "allows_headers_footers": false,
    "font_family": "Calibri",
    "content_layer": "body_only",
    "forbidden_glyphs": ["•", "✔", "★", "❖", "●", "✅", "❌", "|"]
  },

  "palette": {
    "ink_gold": "#C4922A",
    "waratah_red": "#C1272D",
    "warm_cream": "#FFF8F0",
    "gold_tint": "#FDF5DC",
    "body_text": "#1A1A1A",
    "muted_text": "#555555",
    "rule_subtle": "#D8D0C4",
    "white": "#FFFFFF"
  },

  "typography": {
    "base_font": "Calibri",
    "base_size_pt": 11,
    "line_spacing": 1.25,
    "spacing_after_pt": 8,
    "section_heading_tracking_pt": 1.5,
    "section_heading_size_pt": 11
  },

  "page": {
    "margin_top_cm": 2.0,
    "margin_bottom_cm": 2.0,
    "margin_left_cm": 2.5,
    "margin_right_cm": 2.5,
    "background_color": "#FFFFFF"
  },

  "blocks": [
    {
      "block_id": "name_header",
      "type": "name_block",
      "order": 1,
      "tokens": ["{{CONTACT_NAME}}"],
      "content": "{{CONTACT_NAME}}",
      "visualConfig": {
        "font_size_pt": 22,
        "font_weight": "bold",
        "font_color": "#C4922A",
        "text_align": "left",
        "padding_top_pt": 0,
        "padding_bottom_pt": 4,
        "letter_spacing": "normal"
      }
    },

    {
      "block_id": "contact_info",
      "type": "contact_block",
      "order": 2,
      "tokens": [
        "{{CONTACT_PHONE}}",
        "{{CONTACT_EMAIL}}",
        "{{CONTACT_LOCATION}}"
      ],
      "content": "{{CONTACT_PHONE}}    {{CONTACT_EMAIL}}    {{CONTACT_LOCATION}}",
      "visualConfig": {
        "font_size_pt": 10,
        "font_color": "#555555",
        "text_align": "left",
        "padding_top_pt": 4,
        "padding_bottom_pt": 18,
        "line_spacing": 1.2,
        "separator": "inline_spaced",
        "border_bottom": {
          "color": "#C4922A",
          "width_pt": 1.0,
          "style": "solid"
        }
      }
    },

    {
      "block_id": "employer_info",
      "type": "employer_block",
      "order": 3,
      "tokens": [
        "{{EMPLOYER_CONTACT_NAME}}",
        "{{EMPLOYER_ORG}}",
        "{{EMPLOYER_ADDRESS}}"
      ],
      "content": "{{EMPLOYER_CONTACT_NAME}}\n{{EMPLOYER_ORG}}\n{{EMPLOYER_ADDRESS}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.2,
        "margin_top_pt": 14,
        "margin_bottom_pt": 14,
        "separator": "line_break"
      }
    },

    {
      "block_id": "salutation",
      "type": "salutation_block",
      "order": 4,
      "tokens": [
        "{{CURRENT_DATE}}",
        "{{SALUTATION}}"
      ],
      "content": "{{CURRENT_DATE}}\n\n{{SALUTATION}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.2,
        "margin_bottom_pt": 12
      }
    },

    {
      "block_id": "body_paragraphs",
      "type": "body_block",
      "order": 5,
      "tokens": [
        "{{HOOK_PARAGRAPH}}",
        "{{BRIDGE_PARAGRAPH}}",
        "{{EVIDENCE_PARAGRAPH_1}}",
        "{{EVIDENCE_PARAGRAPH_2}}"
      ],
      "content": "{{HOOK_PARAGRAPH}}\n\n{{BRIDGE_PARAGRAPH}}\n\n{{EVIDENCE_PARAGRAPH_1}}\n\n{{EVIDENCE_PARAGRAPH_2}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.35,
        "paragraph_spacing_after_pt": 12
      }
    },

    {
      "block_id": "closing",
      "type": "closing_block",
      "order": 6,
      "tokens": [
        "{{CLOSING_PARAGRAPH}}"
      ],
      "content": "{{CLOSING_PARAGRAPH}}",
      "visualConfig": {
        "font_size_pt": 11,
        "font_color": "#1A1A1A",
        "text_align": "left",
        "line_spacing": 1.35,
        "margin_top_pt": 8
      }
    }
  ]
}
