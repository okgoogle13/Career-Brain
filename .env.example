# Phase 5 Google Docs generation
#
# Option A: OAuth desktop app credentials. The first run opens a local browser
# consent flow and writes GOOGLE_OAUTH_TOKEN.
GOOGLE_OAUTH_CLIENT_SECRETS=credentials.json
GOOGLE_OAUTH_TOKEN=token.json

# Option B: Service account credentials. Share each Golden Master Google Doc
# with the service account email before running generate_document.py.
# GOOGLE_APPLICATION_CREDENTIALS=service-account.json
