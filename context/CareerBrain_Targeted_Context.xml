    r"\.psl$",
    r"\.textClipping$",
    r"\.html$",
    r"\.json$",
    r"\.dotx$",
    r"\.dotm$",
]

# Extra skip patterns for Chromebook Downloads (personal files)
CHROMEBOOK_SKIP_PATTERNS = SKIP_PATTERNS + [
    # Financial / personal
    r"American Express",
    r"OVO Energy",
    r"Invoice",
    r"INVOICE",
    r"Receipt",
    r"SaleReceipt",
